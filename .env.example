# ============================================================================
# DJANGO PRODUCTION CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and update all values for your environment
# NEVER commit .env file with real credentials to git!
# ============================================================================

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# SECURITY WARNING: Generate a new secret key for production!
# Generate using: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# This should be a random string of at least 50 characters
SECRET_KEY=django-insecure-your-secret-key-change-this-in-production

# Debug mode - set to False in production!
# DEBUG=False for production
DEBUG=False

# Allowed hosts - comma separated, no spaces
# PRODUCTION: example.com,www.example.com
# DEVELOPMENT: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# EMAIL CONFIGURATION (for password reset emails)
# ============================================================================

# Email backend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Gmail Configuration Example:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password-not-regular-password
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Alternative: SendGrid
# EMAIL_BACKEND=sendgrid_backend.SendgridBackend
# SENDGRID_API_KEY=your-sendgrid-api-key
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Default: SQLite (development only, not for production)
# ENGINE=sqlite3
# NAME=db.sqlite3

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/propixy_db
# Or use individual settings:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=propixy_db
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
DJANGO_LOG_LEVEL=INFO

# ============================================================================
# TIME & LOCALE
# ============================================================================

# Time Zone (default: Asia/Dhaka)
TIME_ZONE=Asia/Dhaka

# ============================================================================
# STATIC FILES & MEDIA
# ============================================================================

# Static files (CSS, JS, images)
# Default uses local filesystem with WhiteNoise
STATIC_URL=/static/

# Media files (user uploads)
MEDIA_URL=/media/

# For production with AWS S3:
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# ============================================================================
# CACHING (Optional)
# ============================================================================

# Redis (for caching and sessions)
# REDIS_URL=redis://localhost:6379/0
# CACHE_BACKEND=redis://localhost:6379/1
